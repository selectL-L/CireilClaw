# Per-agent engine configuration
# Copy to ~/.cireilclaw/agents/{slug}/config/engine.toml
#
# Same format as the global engine.toml — a record of provider names to configs.
# Per-agent configs override the global engine.toml for this agent.

[my-provider]
apiBase = "https://api.openai.com/v1"
apiKey = "sk-..."
defaultModel = "gpt-4o"
isGlobalDefault = true

# --- Provider fields ---
#
# apiBase               (required)  Valid API base URL
# apiKey                (optional)  String or array of strings for key pooling. Default: "not-needed"
# defaultModel          (required)  The default model identifier
# isGlobalDefault       (optional)  One provider must have this set to true. Default: false
# kind                  (optional)  "openai" or "anthropic". Default: "openai"
# availableModels       (optional)  List of model names, or "analyze" for auto-resolution. Default: "analyze"
# maxGenerationRetries  (optional)  How many times generation can fail before crashing. Default: 2
# maxTurns              (optional)  Number of conversation turns sent to the API. Default: 30
# useFilesApi           (optional)  Use provider files API for media. "kimi" or false. Default: false
# useJpegForImages      (optional)  Force JPEG over WEBP for images. Default: false
# useToolChoiceAuto     (optional)  Prefer tool_choice: auto over required. Default: false
# customHeaders         (optional)  Custom headers for generation requests
#
# models                (optional)  Model-specific overrides, keyed by model name:
#   [my-provider.models.gpt-4o]
#   reasoning = true            # Enable reasoning (true/false), or set to an OpenRouter effort level: "xhigh", "high", "medium", "low", "minimal", "none". Default: true
#   reasoningBudget = 16384     # Token budget for reasoning. Default: 16384
#   supportsVideo = false       # Video support flag. Default: false
#   toolFailThreshold = 3       # Max tool failures before giving up. Default: 3
#   contextWindow = 128000      # Model context window in tokens. Enables token-budget pruning.
#                                 When set, the engine evicts stale tool responses before dropping turns.
#                                 When omitted, legacy maxTurns-only truncation is used.
#   contextBudget = 0.6         # Fraction of contextWindow to prune back to (0.1–1.0). Default: 0.6
#   contextHardBudget = 0.85    # Fraction of contextWindow that triggers pruning (0.1–1.0). Default: 0.85
#                                 Context accumulates from contextBudget up to contextHardBudget,
#                                 then prunes back to contextBudget. This hysteresis improves
#                                 cache hit rates by keeping prefixes stable across turns.
